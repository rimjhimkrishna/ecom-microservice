# ==============================================================================
# E-Commerce Microservices Platform Configuration Template
# Copy this file to '.env' and adjust the values as necessary for your environment.
# ==============================================================================

# User Service Database (PostgreSQL)
USER_DB_URL=jdbc:postgresql://postgres-user:5432/user_db
USER_DB_USERNAME=postgres
USER_DB_PASSWORD=postgres

# Product Service Database (PostgreSQL)
PRODUCT_DB_URL=jdbc:postgresql://postgres-product:5432/product_db
PRODUCT_DB_USERNAME=postgres
PRODUCT_DB_PASSWORD=postgres

# Order Service Database (PostgreSQL)
ORDER_DB_URL=jdbc:postgresql://postgres-order:5432/order_db
ORDER_DB_USERNAME=postgres
ORDER_DB_PASSWORD=postgres

# MongoDB Notification Database
MONGO_URI=mongodb://mongodb:27017/notification_db

# Redis Cache configuration
REDIS_HOST=redis
REDIS_PORT=6379

# Kafka Broker Server
KAFKA_SERVER=kafka:9092

# JWT Security Configurations
# Secret must be HS256 compatible, at least 256 bits (32 bytes) long.
JWT_SECRET=9a3f9e8a7b6c5d4e3f2e1d0c9b8a7f6e5d4c3b2a1f0e9d8c7b6a5f4e3d2c1b0a
JWT_ACCESS_EXPIRY=900000
JWT_REFRESH_EXPIRY=604800000

# Service Discovery (Eureka Server)
EUREKA_URL=http://eureka-server:8761/eureka
